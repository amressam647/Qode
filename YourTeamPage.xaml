<Page x:Class="LocalCursor.Views.YourTeamPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:LocalCursor.Views"
      mc:Ignorable="d" 
      d:DesignHeight="800" d:DesignWidth="600"
      Title="Your Team">

    <Grid Background="{StaticResource BackgroundPrimary}">
        <DockPanel Margin="25">
            <TextBlock DockPanel.Dock="Top" Text="AI TEAM MANAGEMENT" FontSize="22" FontWeight="Bold" Foreground="{StaticResource AccentColor}" Margin="0,0,0,10"/>
            <TextBlock DockPanel.Dock="Top" Text="Assign models and define execution policies for each team role." Foreground="{StaticResource TextSecondary}" Margin="0,0,0,25"/>

            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding RoleBindings}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{StaticResource BackgroundSecondary}" Margin="0,0,0,15" Padding="18" CornerRadius="10" BorderBrush="{StaticResource BorderColor}" BorderThickness="1">
                                <StackPanel>
                                    <Grid>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="&#xE77B;" FontFamily="{StaticResource IconFont}" FontSize="18" Foreground="{StaticResource AccentColor}" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding Role}" FontWeight="Bold" FontSize="15" Foreground="{StaticResource TextForeground}" VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <Button Content="SAVE" HorizontalAlignment="Right" 
                                                Command="{Binding DataContext.SaveRoleAssignmentCommand, RelativeSource={RelativeSource AncestorType=Page}}" 
                                                CommandParameter="{Binding}"
                                                Padding="12,4" Background="{StaticResource AccentColor}" BorderThickness="0"/>
                                    </Grid>

                                    <Grid Margin="0,15,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="MODEL" FontSize="10" FontWeight="SemiBold" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,5"/>
                                            <ComboBox ItemsSource="{Binding DataContext.AllAvailableModelsFormatted, RelativeSource={RelativeSource AncestorType=Page}}"
                                                      SelectedItem="{Binding SelectedModelName}"
                                                      Style="{StaticResource ModernComboBoxStyle}" Height="32"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Margin="20,0,0,0" VerticalAlignment="Bottom">
                                            <CheckBox Content="Auto" IsChecked="{Binding IsAuto}" Foreground="{StaticResource TextSecondary}"/>
                                        </StackPanel>
                                    </Grid>

                                    <StackPanel Margin="0,15,0,0">
                                        <TextBlock Text="EXECUTION POLICY" FontSize="10" FontWeight="SemiBold" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,5"/>
                                        <TextBox Text="{Binding ExecutionPolicy, UpdateSourceTrigger=PropertyChanged}" 
                                                 AcceptsReturn="True" MinHeight="60" TextWrapping="Wrap" 
                                                 Background="{StaticResource InputBackground}" Foreground="{StaticResource TextForeground}"
                                                 BorderBrush="{StaticResource BorderColor}" BorderThickness="1" Padding="8"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </DockPanel>
    </Grid>
</Page>
